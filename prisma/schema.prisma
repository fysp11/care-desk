generator client {
  provider = "prisma-client"
  output   = "./../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  phoneNumber String
  dob         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lastName, firstName])
  @@index([dob])
}
