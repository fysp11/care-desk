{
  "name": "@care-desk/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "tsc -p tsconfig.test.json && vitest run dist-test/test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma --config ../../prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma --config ../../prisma.config.ts",
    "db:migrate:dev": "prisma migrate dev --schema ../../prisma/schema.prisma --config ../../prisma.config.ts",
    "db:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.16.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.27",
    "@types/bcrypt": "6.0.0",
    "@types/pg": "8.20.0",
    "light-my-request": "6.6.0",
    "prisma": "7.8.0"
  }
}
